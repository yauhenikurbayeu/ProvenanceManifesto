---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalPath?: string;
  type?: 'website' | 'article';
  locale?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  image,
  canonicalPath,
  type = 'website',
  locale = 'en',
  noIndex = false
} = Astro.props;

const siteBase = (import.meta.env.SITE_URL || 'https://provenancemanifesto.org').replace(/\/+$/, '');

function toAbsoluteUrl(value: string) {
  if (/^https?:\/\//i.test(value) || value.startsWith('//')) {
    return value;
  }

  const normalizedValue = value.startsWith('/') ? value : `/${value}`;
  return `${siteBase}${normalizedValue}`;
}

const canonicalPathValue = canonicalPath || Astro.url?.pathname || '/';
const canonical = toAbsoluteUrl(canonicalPathValue);
const absoluteImage = image ? toAbsoluteUrl(image) : undefined;

const ogLocale = locale.length === 2 ? `${locale}_${locale.toUpperCase()}` : locale.replace('-', '_');

const ldJson = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Provenance Manifesto',
  description,
  url: canonical
};
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
{noIndex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content="Provenance Manifesto" />
{absoluteImage && <meta property="og:image" content={absoluteImage} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{absoluteImage && <meta name="twitter:image" content={absoluteImage} />}

<link rel="canonical" href={canonical} />
<script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
