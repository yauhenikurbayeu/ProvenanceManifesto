---
import { getLocalizedPath, type SupportedLang, useTranslations } from '../i18n/utils';

interface Props {
    lang: string;
}

const { lang } = Astro.props;
const supportedLang = lang as SupportedLang;
const t = useTranslations(supportedLang);
const signRoute = getLocalizedPath(supportedLang, 'sign');
---

<div class="mt-8 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 bg-white dark:bg-[#151b27] overflow-hidden relative" id="signatories-block">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 mb-4">
        <div>
            <h3 class="text-xl font-bold dark:text-white mb-2">{t('signatures.title')}</h3>
            <p class="text-slate-500 dark:text-slate-400">
                <strong id="sig-count" class="text-[#1152d4] text-xl mr-1">...</strong> {t('signatures.count')}
            </p>
        </div>
        <a href={signRoute} class="bg-[#1152d4] hover:bg-[#1152d4]/90 text-white px-6 py-2 rounded-lg font-bold transition-all shadow-lg shrink-0 w-full md:w-auto text-center">
            {t('nav.sign')}
        </a>
    </div>

    <!-- Scrolling Ticker Container -->
    <div id="sig-ticker-container" class="relative w-full h-8 overflow-hidden mask-edges mt-4 hidden">
        <div id="sig-ticker" class="absolute whitespace-nowrap animate-scroll text-slate-400 dark:text-slate-500 font-medium tracking-wide">
            <!-- Populated via JS -->
        </div>
    </div>
</div>

<script>
    import { createClient } from '@supabase/supabase-js';
    import { getSupabaseClientConfig } from '../i18n/utils';

    async function fetchSignatures() {
        const { url: supabaseUrl, anonKey: supabaseKey } = getSupabaseClientConfig();

        if (!supabaseUrl || !supabaseKey) return;

        const supabase = createClient(supabaseUrl, supabaseKey);
        
        try {
            // Fetch total count (using exact, head-only request for efficiency)
            const { count: total, error: countError } = await supabase
                .from('signatures')
                .select('*', { count: 'exact', head: true });
                
            if (!countError && total !== null) {
                const countEl = document.getElementById('sig-count');
                if (countEl) countEl.textContent = total.toString();
            }

            // Fetch last 15 recent signatures
            // We do not need to obfuscate here anymore, since they are already obfuscated in the DB
            const { data, error: fetchError } = await supabase
                .from('signatures')
                .select('name')
                .order('created_at', { ascending: false })
                .limit(15);
                
            if (!fetchError && data && data.length > 0) {
                const namesString = data.map(s => s.name).join('  •  ');
                // Duplicate once to allow seamless CSS loop animation
                const tickerContent = `<span>${namesString}  •  </span><span>${namesString}  •  </span>`;
                
                const tickerContainer = document.getElementById('sig-ticker-container');
                const tickerEl = document.getElementById('sig-ticker');
                
                if (tickerEl && tickerContainer) {
                    tickerEl.innerHTML = tickerContent;
                    tickerContainer.classList.remove('hidden');
                }
            }
        } catch (e) {
            console.error("Failed to fetch signatures on client", e);
        }
    }

    // Call fetch on script load. Because this is executed in the browser, it hits Supabase dynamically.
    fetchSignatures();
</script>

<style>
    /* CSS animation for the ticker */
    @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    
    .animate-scroll {
        animation: scroll 40s linear infinite;
        display: inline-block;
    }

    /* Gradient mask on edges of ticker */
    .mask-edges {
        mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }
</style>
