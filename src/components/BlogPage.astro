---
import Layout from '../layouts/Layout.astro';
import type { SupportedLang } from '../i18n/utils';
import type { BlogArticle } from '../lib/blog';

interface Props {
  lang: SupportedLang;
  title: string;
  description: string;
  readmePath: string;
  articles: BlogArticle[];
  articleHrefBuilder: (slug: string) => string;
  canonicalPath: string;
}

const {
  lang,
  title,
  description,
  articles,
  articleHrefBuilder,
  canonicalPath
} = Astro.props as Props;

const locale = String(lang);
---

<Layout
  title={`${title} | The Provenance Manifesto`}
  description={description}
  metaLocale={locale}
  lang={lang}
  canonicalPath={canonicalPath}
>
  <div class="max-w-[960px] mx-auto w-full px-6 md:px-10 py-12 md:py-20 flex flex-col gap-12">
    <div class="flex flex-col gap-6 text-center md:text-left">
      <h1 class="text-slate-900 dark:text-white text-4xl md:text-6xl font-black leading-tight tracking-[-0.033em]">
        {title}
      </h1>
      <p class="text-slate-600 dark:text-slate-400 text-lg md:text-xl font-normal max-w-3xl leading-relaxed">
        {description}
      </p>
    </div>

    <div class="flex flex-col gap-4">
      {articles.map((article: BlogArticle, index: number) => (
        <details class="group flex flex-col rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 transition-all duration-300 open:ring-1 open:ring-[#1152d4]/50" open={index === 0}>
          <summary class="flex cursor-pointer items-center justify-between gap-6 px-6 py-5 list-none">
            <div class="flex items-center gap-4 min-w-0">
              <span class="flex items-center justify-center size-8 rounded-full bg-[#1152d4]/10 text-[#1152d4] font-bold text-sm shrink-0">✓</span>
              <div class="flex flex-col min-w-0 gap-1">
                <a
                  href={articleHrefBuilder(article.slug)}
                  class="text-slate-900 dark:text-white text-lg font-bold leading-normal hover:text-[#1152d4] transition-colors truncate"
                >
                  {article.title}
                </a>
                <p class="text-sm text-slate-500 dark:text-slate-400">{article.publishedLabel}</p>
              </div>
            </div>
            <span class="material-symbols-outlined text-slate-400 group-open:rotate-180 transition-transform shrink-0">expand_more</span>
          </summary>
          <div class="px-6 pb-6 pt-0 ml-12 flex flex-col gap-3">
            <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">TL;DR</h3>
            <p class="text-slate-600 dark:text-slate-300 text-base font-normal leading-relaxed">{article.tldr}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</Layout>
