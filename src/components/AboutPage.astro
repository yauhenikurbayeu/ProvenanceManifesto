---
import Layout from '../layouts/Layout.astro';
import { type SupportedLang } from '../i18n/utils';
import contentEn from '../i18n/en/content.json';
import contentEs from '../i18n/es/content.json';
import contentFr from '../i18n/fr/content.json';
import contentRu from '../i18n/ru/content.json';
import contentDe from '../i18n/de/content.json';
import contentPl from '../i18n/pl/content.json';

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;

const contentMap = {
  en: contentEn,
  es: contentEs,
  fr: contentFr,
  ru: contentRu,
  de: contentDe,
  pl: contentPl
};
const content = contentMap[lang as keyof typeof contentMap].about;
const locale = String(lang);

const seoTitle = `${content.title} | The Provenance Manifesto`;
const seoDescription = content.subtitle;
---

<Layout title={seoTitle} description={seoDescription} metaLocale={locale} lang={lang}>
    <div class="flex-1 flex flex-col items-center py-12 md:py-24 px-6">
        <article class="max-w-2xl w-full">
            <header class="mb-16">
                <h1 class="text-slate-900 dark:text-white text-5xl md:text-6xl font-black leading-tight tracking-[-0.033em] mb-6 font-display">
                    {content.title}
                </h1>
                <p class="text-slate-500 dark:text-slate-400 text-xl font-normal leading-relaxed italic border-l-4 border-[#1152d4]/50 pl-6 py-2">
                    {content.subtitle}
                </p>
            </header>

            <div class="w-full aspect-video rounded-xl overflow-hidden mb-16 bg-slate-800">
                <img alt="Feather pen and inkwell on old paper" class="w-full h-full object-cover grayscale opacity-70" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBem3ASdR6G-x1YZc53y1OAMtbpn3tGL6sMF050xcXfuexskji5J8wHzvjG5gw4uqiKGXY7D_26w3z9Y4zmLNXJQ1Dx7VHj7iQ7WxEj6fWx5J7hi60Q_2SfvuDMKKtaww4GfJBS5HLIKimPxSMTxA56DYJUmOUBCc0Kn0yumvYcFCm5MFB94s5ng5K6KdjeEwImp1n-BHbdxW1xiaBuUl32fqAzkErGabR3Oi3K-q39LAsE-pvknSSg1pM3R7GBp3vyHwg4ZWHvdFU" />
            </div>

            <div class="space-y-12 text-slate-800 dark:text-slate-200 text-lg leading-8">
                {content.sections.map((section, idx) => (
                    <section class={idx === 2 ? 'bg-[#1152d4]/5 dark:bg-[#1152d4]/10 p-8 rounded-xl border border-[#1152d4]/20' : ''}>
                        <h2 class="text-slate-900 dark:text-white text-3xl font-bold mb-6 font-display">{section.title}</h2>
                        {section.content.map((p) => (
                            <p class="mb-6">{p}</p>
                        ))}
                    </section>
                ))}
            </div>
        </article>
    </div>
</Layout>
