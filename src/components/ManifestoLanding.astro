---
import Layout from '../layouts/Layout.astro';
import { getLocalizedPath, type SupportedLang, useTranslations } from '../i18n/utils';
import contentEn from '../i18n/en/content.json';
import contentEs from '../i18n/es/content.json';
import contentFr from '../i18n/fr/content.json';
import contentRu from '../i18n/ru/content.json';
import contentDe from '../i18n/de/content.json';
import contentPl from '../i18n/pl/content.json';
import Signatories from './Signatories.astro';

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const contentMap = {
  en: contentEn,
  es: contentEs,
  fr: contentFr,
  ru: contentRu,
  de: contentDe,
  pl: contentPl
};
const content = contentMap[lang as keyof typeof contentMap].landing;
const englishValues = contentEn.landing.values;

function slugify(value: string) {
  return value
    .trim()
    .toLowerCase()
    .normalize('NFKD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .replace(/-+/g, '-');
}

const getValueId = (index: number) => {
  const sourceValue = englishValues[index]?.left || content.values[index]?.left || '';
  return slugify(sourceValue);
};

const seoTitle = `The Provenance Manifesto | ${content.hero_title_highlight}`;
const seoDescription = content.hero_description;
const locale = String(lang);
---

<Layout title={seoTitle} description={seoDescription} metaLocale={locale} lang={lang}>
    <section class="relative pt-24 pb-32 px-6 overflow-hidden">
        <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
            <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-[#1152d4]/30 blur-[120px] rounded-full"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[30%] h-[30%] bg-[#1152d4]/20 blur-[100px] rounded-full"></div>
        </div>
        <div class="max-w-4xl mx-auto relative z-10 text-center">
            <h1 class="text-5xl md:text-7xl font-black tracking-tight mb-8 leading-[1.1]">
                {content.hero_title_prefix} <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#1152d4] to-blue-400">{content.hero_title_highlight}</span> {content.hero_title_suffix}
            </h1>
            <p class="text-xl md:text-2xl font-light leading-relaxed text-slate-600 dark:text-slate-300 max-w-3xl mx-auto">
                {content.hero_description}
            </p>
            <div class="mt-12">
                <a href={getLocalizedPath(lang, 'principles')} class="inline-block bg-slate-900 dark:bg-slate-100 text-slate-100 dark:text-slate-900 px-8 py-4 rounded-xl font-bold text-lg hover:opacity-90 transition-opacity">
                    {t('hero.read')}
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 px-6 bg-slate-50 dark:bg-[#101622]/50">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-2xl md:text-3xl font-bold mb-12 text-center md:text-left">{content.values_title}</h2>
            <div class="space-y-6">
                {content.values.map((val, index) => (
                    <div class="group p-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-[#101622] hover:border-[#1152d4]/50 transition-colors">
                        <div class="grid md:grid-cols-2 gap-4 md:gap-6 items-start">
                        <div class="flex items-start gap-4 min-w-0">
                            <span class="material-symbols-outlined text-[#1152d4]">{val.icon}</span>
                            <span class="text-lg font-semibold text-[#1152d4] break-words" id={getValueId(index)}>
                              {val.left}
                            </span>
                        </div>
                        <div class="mt-2 md:mt-0 flex items-start gap-3 min-w-0">
                            <span class="text-slate-400 italic text-sm md:text-base shrink-0">{t('hero.over')}</span>
                            <span class="text-lg font-medium text-slate-500 dark:text-slate-400 break-words">{val.right}</span>
                        </div>
                    </div>
                    </div>
                ))}
            </div>
            <div class="mt-12 text-center">
                <p class="text-slate-500 dark:text-slate-400 italic font-light leading-relaxed">
                    {content.disclaimer}
                </p>
            </div>
        </div>
    </section>

    <section class="py-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="h-[300px] w-full rounded-2xl bg-gradient-to-br from-slate-900 via-[#1152d4]/40 to-slate-900 border border-slate-800 flex items-center justify-center overflow-hidden relative" data-alt="Deep blue abstract geometric pattern representing connectivity and data flow">
                <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-20"></div>
                <div class="relative z-10 text-center px-6">
                    <blockquote class="text-2xl md:text-3xl font-light italic text-white max-w-2xl mb-8">
                        {content.quote}
                    </blockquote>
                </div>
            </div>

            <div class="mt-12 max-w-4xl mx-auto">
                <Signatories lang={lang as string} />
            </div>
        </div>
    </section>
</Layout>
