---
import '../styles/global.css';
import { getLocalizedPath, useTranslations } from '../i18n/utils';
import type { SupportedLang } from '../i18n/utils';
import { defaultLang } from '../i18n/ui';
import SEO from '../components/SEO.astro';

interface Props {
	title: string;
	description: string;
	metaImage?: string;
	metaType?: 'website' | 'article';
	metaLocale?: string;
	metaNoIndex?: boolean;
	lang?: SupportedLang;
}

const {
	title,
	description,
	metaImage,
	metaType,
	metaLocale,
	metaNoIndex,
	lang = defaultLang
} = Astro.props;
const activeLang = lang;
const t = useTranslations(lang);
const baseUrl = import.meta.env.BASE_URL || '/';
---

<!doctype html>
<html lang={activeLang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
        <SEO
            title={title}
            description={description}
            image={metaImage}
            type={metaType}
            locale={metaLocale}
            noIndex={metaNoIndex}
        />

		<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-[#f6f6f8] dark:bg-[#101622] text-slate-900 dark:text-slate-100 antialiased min-h-screen flex flex-col font-['Public_Sans',sans-serif]">
        <!-- Top Navigation Bar -->
	<header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-[#f6f6f8]/80 dark:bg-[#101622]/80 backdrop-blur-md">
            <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
                <button
                    id="menu-button"
                    type="button"
                    class="md:hidden inline-flex items-center justify-center size-9 rounded-lg text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                    aria-controls="mobile-menu"
                    aria-expanded="false"
                    aria-label="Open menu"
                >
                    <span id="menu-open-icon" class="material-symbols-outlined text-2xl">menu</span>
                    <span id="menu-close-icon" class="material-symbols-outlined text-2xl hidden">close</span>
                </button>

                <a href={getLocalizedPath(activeLang)} class="flex items-center gap-3">
                    <span aria-hidden="true" class="material-symbols-outlined text-[#1152d4] text-2xl">fingerprint</span>
                    <span class="text-lg font-bold tracking-tight">Provenance Manifesto</span>
                </a>
                
                <nav class="hidden md:flex items-center gap-8">
                    <a href={getLocalizedPath(activeLang)} class="text-sm font-medium hover:text-[#1152d4] transition-colors">{t('nav.manifesto')}</a>
                    <a href={getLocalizedPath(activeLang, 'principles')} class="text-sm font-medium hover:text-[#1152d4] transition-colors">{t('nav.principles')}</a>
                    <a href={getLocalizedPath(activeLang, 'about')} class="text-sm font-medium hover:text-[#1152d4] transition-colors">{t('nav.about')}</a>
                    
                    <div class="h-4 w-[1px] bg-slate-300 dark:bg-slate-700 mx-2"></div>
                    
                    <div class="flex items-center gap-3 text-xs font-semibold uppercase tracking-widest text-slate-500">
                        <a href={getLocalizedPath('en')} class={activeLang === 'en' ? 'text-[#1152d4]' : 'hover:text-slate-300 transition-colors'}>EN</a>
                        <a href={getLocalizedPath('es')} class={activeLang === 'es' ? 'text-[#1152d4]' : 'hover:text-slate-300 transition-colors'}>ES</a>
                        <a href={getLocalizedPath('fr')} class={activeLang === 'fr' ? 'text-[#1152d4]' : 'hover:text-slate-300 transition-colors'}>FR</a>
                        <a href={getLocalizedPath('ru')} class={activeLang === 'ru' ? 'text-[#1152d4]' : 'hover:text-slate-300 transition-colors'}>RU</a>
                        <a href={getLocalizedPath('de')} class={activeLang === 'de' ? 'text-[#1152d4]' : 'hover:text-slate-300 transition-colors'}>DE</a>
                        <a href={getLocalizedPath('pl')} class={activeLang === 'pl' ? 'text-[#1152d4]' : 'hover:text-slate-300 transition-colors'}>PL</a>
                    </div>
                </nav>
                
                <a href={getLocalizedPath(activeLang, 'sign')} class="hidden md:inline-flex bg-[#1152d4] hover:bg-[#1152d4]/90 text-white px-5 py-2 rounded-lg text-sm font-bold transition-all shadow-lg shadow-[#1152d4]/20">
                    {t('nav.sign')}
                </a>
            </div>
        </header>

        <div
            id="mobile-menu"
            class="md:hidden overflow-hidden transition-all duration-200 ease-in-out bg-[#f6f6f8]/95 dark:bg-[#101622]/95 border-b border-slate-200/0 dark:border-slate-800/0"
            style="max-height: 0; opacity: 0;"
            aria-hidden="true"
        >
            <div class="px-6 py-4 space-y-4">
                <nav class="flex flex-col gap-2 border-b border-slate-200 dark:border-slate-800 pb-4">
                    <a href={getLocalizedPath(activeLang)} class="text-sm font-medium py-2 hover:text-[#1152d4] transition-colors">{t('nav.manifesto')}</a>
                    <a href={getLocalizedPath(activeLang, 'principles')} class="text-sm font-medium py-2 hover:text-[#1152d4] transition-colors">{t('nav.principles')}</a>
                    <a href={getLocalizedPath(activeLang, 'about')} class="text-sm font-medium py-2 hover:text-[#1152d4] transition-colors">{t('nav.about')}</a>
                </nav>

                <div class="flex flex-wrap items-center gap-2 pt-4">
                    <a href={getLocalizedPath('en')} class={activeLang === 'en' ? 'text-[#1152d4] px-2 py-1 rounded-md text-xs font-semibold' : 'text-slate-500 hover:text-slate-900 dark:hover:text-slate-200 px-2 py-1 rounded-md text-xs font-semibold transition-colors'}>EN</a>
                    <a href={getLocalizedPath('es')} class={activeLang === 'es' ? 'text-[#1152d4] px-2 py-1 rounded-md text-xs font-semibold' : 'text-slate-500 hover:text-slate-900 dark:hover:text-slate-200 px-2 py-1 rounded-md text-xs font-semibold transition-colors'}>ES</a>
                    <a href={getLocalizedPath('fr')} class={activeLang === 'fr' ? 'text-[#1152d4] px-2 py-1 rounded-md text-xs font-semibold' : 'text-slate-500 hover:text-slate-900 dark:hover:text-slate-200 px-2 py-1 rounded-md text-xs font-semibold transition-colors'}>FR</a>
                    <a href={getLocalizedPath('ru')} class={activeLang === 'ru' ? 'text-[#1152d4] px-2 py-1 rounded-md text-xs font-semibold' : 'text-slate-500 hover:text-slate-900 dark:hover:text-slate-200 px-2 py-1 rounded-md text-xs font-semibold transition-colors'}>RU</a>
                    <a href={getLocalizedPath('de')} class={activeLang === 'de' ? 'text-[#1152d4] px-2 py-1 rounded-md text-xs font-semibold' : 'text-slate-500 hover:text-slate-900 dark:hover:text-slate-200 px-2 py-1 rounded-md text-xs font-semibold transition-colors'}>DE</a>
                    <a href={getLocalizedPath('pl')} class={activeLang === 'pl' ? 'text-[#1152d4] px-2 py-1 rounded-md text-xs font-semibold' : 'text-slate-500 hover:text-slate-900 dark:hover:text-slate-200 px-2 py-1 rounded-md text-xs font-semibold transition-colors'}>PL</a>
                </div>

                <a href={getLocalizedPath(activeLang, 'sign')} class="inline-flex w-full justify-center bg-[#1152d4] hover:bg-[#1152d4]/90 text-white px-5 py-3 rounded-lg text-sm font-bold transition-all shadow-lg shadow-[#1152d4]/20">
                    {t('nav.sign')}
                </a>
            </div>
        </div>

        <main class="flex-1">
		    <slot />
        </main>

        <!-- Footer -->
        <footer class="border-t border-slate-200 dark:border-slate-800 py-16 px-6">
            <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
                <div class="flex items-center gap-3">
                    <span aria-hidden="true" class="material-symbols-outlined text-[#1152d4]">fingerprint</span>
                    <span class="text-lg font-bold tracking-tight">Provenance Manifesto</span>
                </div>

                <a
                    href="https://www.linkedin.com/in/yauhenikurbayeu/recent-activity/all/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-slate-500 dark:text-slate-400 hover:text-[#1152d4] transition-colors"
                >
                    {t('footer.linkedin')}
                </a>

                <div class="flex flex-col items-end gap-2 text-right">
                    <p class="text-sm text-slate-500 dark:text-slate-400">
                        © 2026 Provenance Manifesto. {t('footer.rights')}
                    </p>
                </div>
            </div>
        </footer>

        <script is:inline>
            const menuButton = document.getElementById('menu-button');
            const mobileMenu = document.getElementById('mobile-menu');
            const menuOpenIcon = document.getElementById('menu-open-icon');
            const menuCloseIcon = document.getElementById('menu-close-icon');
            const desktopQuery = window.matchMedia('(min-width: 768px)');
            let isMenuOpen = false;

            const setMenuState = (next) => {
                if (!mobileMenu || !menuButton) return;
                isMenuOpen = next;
                menuButton.setAttribute('aria-expanded', String(isMenuOpen));
                menuButton.setAttribute('aria-label', isMenuOpen ? 'Close menu' : 'Open menu');

                if (isMenuOpen) {
                    mobileMenu.style.maxHeight = `${mobileMenu.scrollHeight}px`;
                    mobileMenu.style.opacity = '1';
                    mobileMenu.setAttribute('aria-hidden', 'false');
                    menuOpenIcon?.classList.add('hidden');
                    menuCloseIcon?.classList.remove('hidden');
                    return;
                }

                mobileMenu.style.maxHeight = '0px';
                mobileMenu.style.opacity = '0';
                mobileMenu.setAttribute('aria-hidden', 'true');
                menuOpenIcon?.classList.remove('hidden');
                menuCloseIcon?.classList.add('hidden');
            };

            menuButton?.addEventListener('click', () => {
                if (desktopQuery.matches) return;
                setMenuState(!isMenuOpen);
            });

            document.querySelectorAll('#mobile-menu a').forEach((link) => {
                link.addEventListener('click', () => setMenuState(false));
            });

            desktopQuery.addEventListener('change', (event) => {
                if (event.matches) {
                    setMenuState(false);
                }
            });

            window.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    setMenuState(false);
                }
            });
        </script>
    </body>
</html>
<style is:global>
    /* Global styles can go here if needed */
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>
