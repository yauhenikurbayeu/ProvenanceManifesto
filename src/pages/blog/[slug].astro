---
import BlogArticlePage from '../../components/BlogArticlePage.astro';
import { getEnglishBlogArticles, getMarkdownRenderResult, type BlogArticle } from '../../lib/blog';

export function getStaticPaths() {
  return getEnglishBlogArticles({ includeHidden: true }).map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props as { article: BlogArticle };
const renderResult = getMarkdownRenderResult(article.sourcePath);
if (!renderResult) {
  throw new Error(`Unable to load blog article source: ${article.sourcePath}`);
}
---

<BlogArticlePage
  lang="en"
  article={article}
  canonicalPath={`/blog/${article.slug}`}
  backToBlogPath="/blog"
  contentHtml={renderResult.html}
  contentToc={renderResult.toc}
/>
