---
import BlogPage from '../../components/BlogPage.astro';
import { getBlogCategoryLabel, useTranslations } from '../../i18n/utils';
import {
  getBlogCategoryKeys,
  getLocalizedBlogArticlesByCategory,
  getPrimaryBlogCategoryKey
} from '../../lib/blog';

const categoryKeys = getBlogCategoryKeys();
const activeCategory = getPrimaryBlogCategoryKey();
const articles = getLocalizedBlogArticlesByCategory('en', activeCategory);
const t = useTranslations('en');
const categoryLinks = categoryKeys.map((category) => ({
  key: category,
  label: getBlogCategoryLabel('en', category),
  href: `/blog/category/${category}`,
  isActive: category === activeCategory
}));
---

<BlogPage
  lang="en"
  title={t('blog.title')}
  description={t('blog.description')}
  articles={articles}
  categoryLinks={categoryLinks}
  canonicalPath={`/blog/category/${activeCategory}`}
  articleHrefBuilder={(slug: string) => `/blog/${slug}`}
/>
