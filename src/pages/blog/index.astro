---
import BlogPage from '../../components/BlogPage.astro';
import { useTranslations } from '../../i18n/utils';
import { getEnglishBlogArticles } from '../../lib/blog';

const articles = getEnglishBlogArticles();
const t = useTranslations('en');
---

<BlogPage
  lang="en"
  title={t('blog.title')}
  description={t('blog.description')}
  articles={articles}
  canonicalPath="/blog"
  articleHrefBuilder={(slug: string) => `/blog/${slug}`}
/>
