---
import BlogPage from '../../../components/BlogPage.astro';
import {
  getBlogCategoryLabel,
  getLocalizedBlogCategoryPath,
  getLocalizedPath,
  type SupportedLang,
  useTranslations
} from '../../../i18n/utils';
import {
  getBlogCategoryKeys,
  getLocalizedBlogArticlesByCategory,
  getLocalizedBlogLanguages,
  getPrimaryBlogCategoryKey
} from '../../../lib/blog';

export function getStaticPaths() {
  return getLocalizedBlogLanguages().map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const normalizedLang = lang as SupportedLang;

const categoryKeys = getBlogCategoryKeys();
const activeCategory = getPrimaryBlogCategoryKey();
const articles = getLocalizedBlogArticlesByCategory(normalizedLang, activeCategory);
const blogPath = getLocalizedPath(normalizedLang, 'blog');
const t = useTranslations(normalizedLang);
const categoryLinks = categoryKeys.map((category) => ({
  key: category,
  label: getBlogCategoryLabel(normalizedLang, category),
  href: getLocalizedBlogCategoryPath(normalizedLang, category),
  isActive: category === activeCategory
}));
---

<BlogPage
  lang={normalizedLang}
  title={t('blog.title')}
  description={t('blog.description')}
  articles={articles}
  categoryLinks={categoryLinks}
  canonicalPath={getLocalizedBlogCategoryPath(normalizedLang, activeCategory)}
  articleHrefBuilder={(slug: string) => `${blogPath}/${slug}`}
/>
